{
  "name": "ro-database",
  "version": "0.1.0",
  "private": true,
  "description": "Banco de dados de Ragnarok Online para LATAM - dados de itens, monstros, skills, mapas e consultas de drop/spawn",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "migrate": "tsx scripts/migrate.ts",
    "seed": "tsx scripts/seed.ts",
    "db:reset": "tsx scripts/migrate.ts && tsx scripts/seed.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test --import tsx ./test/*.test.ts"
  },
  "dependencies": {
    "fastify": "^4.28.1",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "@types/pg": "^8.11.6",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  }
}
